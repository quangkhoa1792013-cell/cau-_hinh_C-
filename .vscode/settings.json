{
  "editor.formatOnSave": false,
  // 1. Giữ IntelliSense của Microsoft để gợi ý code
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.intelliSenseEngineFallback": "disabled",
  // 2. Cấu hình Clangd chỉ để báo lỗi và hiện hints
  "clangd.arguments": [
    "--header-insertion=never",
    "--query-driver=C:\\TDM-GCC-64\\bin\\*.exe",
    "--background-index",
    // Chế độ này giúp Clangd tập trung vào báo lỗi nhanh
    "--clang-tidy",
    "--inlay-hints=false"
  ],
  // 3. Quan trọng: Để tránh hiện 2 bảng gợi ý chồng lên nhau
  "[cpp]": {
    "editor.suggest.showSnippets": true,
    "editor.suggest.showWords": false
  },

  "C_Cpp_Runner.cCompilerPath": "C:/Program Files/LLVM/bin/clang.exe",
  "C_Cpp_Runner.cppCompilerPath": "C:/Program Files/LLVM/bin/clang++.exe",
  "C_Cpp_Runner.debuggerPath": "C:/TDM-GCC-64/bin/gdb.exe",
  "C_Cpp_Runner.cStandard": "c17",
  "C_Cpp_Runner.cppStandard": "c++20",
  "C_Cpp_Runner.useMsvc": false,
  "C_Cpp_Runner.warnings": [
    "-Wall",
    "-Wextra",
    "-Wpedantic",
    "-Wshadow",
    "-Wformat=2",
    "-Wcast-align",
    "-Wconversion",
    "-Wsign-conversion",
    "-Wnull-dereference"
  ],
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [
    "--target=x86_64-w64-windows-gnu",
    "-stdlib=libstdc++",
    "-O3",
    "-march=native"
  ],
  "C_Cpp_Runner.linkerArgs": ["-fuse-ld=lld"],
  "C_Cpp_Runner.includePaths": [
    "${workspaceFolder}/**",
    "C:/TDM-GCC-64/include/**"
  ],
  "C_Cpp_Runner.showCompilationTime": true,
  "C_Cpp_Runner.useLinkTimeOptimization": true,
  "C_Cpp_Runner.msvcSecureNoWarnings": false,
  "C_Cpp.files.exclude": {
    "**/.vscode": true,
    "**/*.exe": true
  },
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ]
}
